{
  "name": "@warpkeep/auth-bridge",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Farcaster SIWF to Warpkeep OIDC bridge for Cloudflare Workers",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "typecheck:workerd": "tsc --noEmit -p test-workerd/tsconfig.json",
    "test": "vitest run",
    "test:workerd": "vitest run --config vitest.workerd.config.ts",
    "check": "pnpm run typecheck && pnpm run typecheck:workerd && pnpm run test && pnpm run test:workerd"
  },
  "dependencies": {
    "@farcaster/auth-client": "0.7.1",
    "viem": "2.55.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@cloudflare/workers-types": "5.20260708.1",
    "@types/node": "26.1.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
