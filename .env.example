# Public browser configuration only. Copy to an untracked .env for local work.
# Shared alpha stays fail-closed until this explicit switch and every public
# bridge value are valid. No VITE_ variable may contain a secret.
VITE_WARPKEEP_SHARED_ALPHA_ENABLED=false
VITE_SPACETIMEDB_URI=https://maincloud.spacetimedb.com
VITE_SPACETIMEDB_DATABASE=warpkeep-89e4u
VITE_WARPKEEP_AUTH_BRIDGE_URL=
VITE_WARPKEEP_OIDC_ISSUER=
VITE_WARPKEEP_OIDC_AUDIENCE=warpkeep-spacetimedb
VITE_WARPKEEP_RELEASE_CHANNEL=alpha
VITE_WARPKEEP_BUILD_SHA=
VITE_WARPKEEP_REPOSITORY_URL=https://github.com/ael-dev3/Warpkeep

# Never add signing keys, Farcaster RPC URLs, admin secrets, resolver tokens,
# admin JWTs, or Maincloud credentials to VITE_ variables or this file.
