  "dependencies": {
    "@farcaster/auth-client": "0.7.1",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "spacetimedb": "2.6.1",
    "three": "0.185.1",
    "viem": "2.55.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.0",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "sharp": "0.35.3",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "vite": "8.0.16",
