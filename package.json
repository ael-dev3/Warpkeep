    "preview": "vite preview",
    "check": "npm run verify:licenses && npm run verify:runtime-assets && npm run verify:file-sizes && npm test && npm run typecheck && npm run build",
    "validate:pages-config": "node scripts/validate-pages-deploy-config.mjs",
    "verify:licenses": "node scripts/verify-license-policy.mjs",
