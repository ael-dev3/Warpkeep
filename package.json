{
  "name": "warpkeep",
  "private": true,
  "version": "0.3.2",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "validate:pages-config": "node scripts/validate-pages-deploy-config.mjs",
    "verify:licenses": "node scripts/verify-license-policy.mjs",
    "verify:alpha-production": "node scripts/verify-alpha-production.mjs",
    "assets:fetch": "node scripts/fetch-title-assets.mjs",
    "prepare:title-models": "node scripts/prepare-title-models.mjs",
    "prepare:hegemony-keep": "node scripts/prepare-hegemony-frontier-keep.mjs",
    "verify:runtime-assets": "node scripts/verify-runtime-assets.mjs",
    "verify:file-sizes": "node scripts/verify-file-sizes.mjs",
    "stdb:version": "spacetime --version",
    "stdb:build": "spacetime build --module-path spacetimedb",
    "stdb:generate": "node scripts/generate-spacetime-bindings.mjs",
    "stdb:verify-bindings": "node scripts/verify-spacetime-bindings.mjs",
    "stdb:verify-additive-migration": "node scripts/verify-spacetime-additive-migration.mjs",
    "stdb:publish:dev": "node scripts/publish-spacetime-dev.mjs",
    "stdb:logs:dev": "spacetime logs --server maincloud warpkeep-89e4u",
    "stdb:seed-world": "tsx scripts/hermes-admin.ts seed-world",
    "stdb:allow-fid": "tsx scripts/hermes-admin.ts allow-fid",
    "stdb:disable-fid": "tsx scripts/hermes-admin.ts disable-fid",
    "stdb:bump-auth-epoch": "tsx scripts/hermes-admin.ts bump-auth-epoch",
    "stdb:inspect-alpha": "tsx scripts/hermes-admin.ts inspect-alpha",
    "stdb:inspect-alpha-v2": "tsx scripts/hermes-admin.ts inspect-alpha-v2",
    "test": "vitest --run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@farcaster/auth-client": "0.7.1",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "spacetimedb": "2.6.1",
    "three": "0.185.1",
    "viem": "2.55.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.0",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "tsx": "4.23.0",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
